# Frontend Environment Variables Template
# Copy this file to '.env' internally if running outside Docker

# Defines the root host boundary for all Backend ASP.NET calls.
# Note: If running via the NGINX stack, leave this empty to default to the relative '/api' proxy!
VITE_API_BASE_URL=http://localhost:9384/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
